{
  "env": {
    "DISPLAY": ":99"
  },
  "permissions": {
    "allow": [
      "Bash(.claude/skills/browser-use/headed-browser/ensure.sh)",
      "Bash(.claude/skills/browser-use/headed-browser/profile.sh:*)",
      "Bash(.claude/skills/browser-use/headed-browser/start.sh)",
      "Bash(.claude/skills/browser-use/headed-browser/stop.sh)",
      "Bash(sudo systemctl start balam:*)",
      "Bash(sudo systemctl stop balam:*)",
      "Bash(sudo systemctl restart balam:*)",
      "Bash(sudo systemctl start cloudflared-balam:*)",
      "Bash(sudo systemctl stop cloudflared-balam:*)",
      "Bash(sudo systemctl restart cloudflared-balam:*)",
      "Bash(systemctl status:*)",
      "Bash(systemctl --no-pager status:*)",
      "Bash(journalctl:*)",
      "Bash(playwright-cli:*)",
      "Bash(xdpyinfo:*)"
    ]
  }
}
