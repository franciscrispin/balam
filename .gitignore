# Dependencies
node_modules/

# Build output
dist/
apps/*/dist/

# Environment
.env
.env.local

# Local workspace contexts (personal paths; config.example.yaml is tracked)
config.yaml

# Logs
*.log

# Local SQLite topic→session map (ADR-0009)
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Python backend (apps/backend, uv)
__pycache__/
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

# OS / editor
.DS_Store
.vscode/

# Generated playwright-cli config (browser-use skill; written by headed-browser/ensure.sh)
.playwright/
.playwright-cli/

# Claude Code local settings (personal; shared config and skills are tracked)
.claude/settings.local.json

# Claude Code agent worktrees (transient per-agent git worktrees)
.claude/worktrees/

# OpenCode agent working files (transient plan files written per session)
.opencode/

# Generated public-mode overlay (holds the current tunnel URL; ADR-0013 deploy)
deploy/balam.env

# Google Calendar OAuth client + token files
.secrets/
