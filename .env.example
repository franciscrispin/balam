# Copy to .env and fill in. Bun loads .env automatically.

# --- Telegram (ADR-0008) ---
# Bot token from @BotFather. Keep it secret; never commit the real value.
TELEGRAM_BOT_TOKEN=
# Numeric user ID of the single allowed owner. Updates from anyone else are ignored.
ALLOWED_TELEGRAM_USER_ID=

# --- OpenCode server (ADR-0001 / 0002 / 0007) ---
# The headless OpenCode server. Bind it to localhost only.
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_SERVER_PASSWORD=

# --- Balam backend ---
# Port the backend listens on (Mini App + API + noVNC proxy).
BALAM_PORT=3000
# Working directory the agent acts on.
BALAM_WORKDIR=/home/ubuntu/projects/balam

# --- noVNC live Chrome view (ADR-0006) ---
# websockify endpoint, bound to localhost. The backend reverse-proxies it.
VNC_WS_URL=ws://127.0.0.1:6080
