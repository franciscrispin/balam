# Copy to .env and fill in. The Python backend loads this repo-root file via
# pydantic-settings; real environment variables (e.g. from systemd) override it.

# --- Telegram (ADR-0008) ---
# Bot token from @BotFather. Keep it secret; never commit the real value.
TELEGRAM_BOT_TOKEN=
# Numeric user ID of the single allowed owner. Updates from anyone else are ignored.
ALLOWED_TELEGRAM_USER_ID=
# Optional: the -100… chat id of the forum supergroup Balam targets (e.g. "workspace").
# When set, the bot only acts on the owner INSIDE this chat (ADR-0008/0010); leave
# blank for the legacy owner-anywhere DM behavior. The owner-id allowlist always applies.
ALLOWED_TELEGRAM_CHAT_ID=

# --- Agent backend (ADR-0014) ---
# Which coding-agent runtime drives Balam: "opencode" (default, the headless
# OpenCode server below) or "claude_sdk" (the in-process Claude Agent SDK).
# The OpenCode settings matter only for "opencode"; the SDK settings only for
# "claude_sdk". Note: "claude_sdk" runs Claude models, so a context's model
# should be a bare Claude id/alias (e.g. claude-opus-4-8) rather than provider/model.
AGENT_BACKEND=opencode

# --- Claude Agent SDK (ADR-0014; only when AGENT_BACKEND=claude_sdk) ---
# API key for the SDK's `claude` subprocess. Optional: if unset, the SDK falls
# back to ANTHROPIC_API_KEY in the environment or an already-authenticated Claude
# CLI (e.g. a subscription login).
ANTHROPIC_API_KEY=
# Override the bundled `claude` CLI path the SDK spawns, if needed.
# CLAUDE_SDK_CLI_PATH=

# --- OpenCode server (ADR-0001 / 0002 / 0007; only when AGENT_BACKEND=opencode) ---
# The headless OpenCode server. Bind it to localhost only.
OPENCODE_BASE_URL=http://127.0.0.1:4096
# A secret you generate yourself (e.g. `openssl rand -hex 32`), NOT issued by a
# third party. Set the SAME value when launching the server:
#   OPENCODE_SERVER_PASSWORD=<secret> opencode serve --hostname 127.0.0.1 --port 4096
# The server then requires HTTP Basic auth: base64("opencode:<password>") in the
# Authorization header. Username defaults to "opencode" (override via
# OPENCODE_SERVER_USERNAME on both sides). The backend injects this header on
# every request, including the SSE stream (balam/opencode.py). Leave blank if the
# server runs without a password. Docs: https://opencode.ai/docs/server/
OPENCODE_SERVER_PASSWORD=
# HTTP Basic username; only set if you overrode the server's default.
# OPENCODE_SERVER_USERNAME=opencode

# --- Balam backend ---
# How tool calls render in the progress stream. "collapsed" (default) folds a
# burst of consecutive calls into one summary line ("Ran 3 commands, read a
# file") with the per-call detail inside a tap-to-expand blockquote; "full"
# keeps the one-line-per-call stream.
# TOOL_STREAM=collapsed
# Port the FastAPI Mini App server will listen on (Mini App + API + noVNC proxy),
# bound to 127.0.0.1 (ADR-0007).
BALAM_PORT=3000
# Public HTTPS base URL the Mini App is reachable at (e.g. an https tunnel). When
# set, /diff offers a native in-Telegram web_app button (Telegram requires HTTPS);
# unset, /diff replies with the local http://127.0.0.1 URL to open in a browser.
# BALAM_PUBLIC_URL=https://balam.example.com
# BotFather Mini App short name (ADR-0013). When set (with BALAM_PUBLIC_URL), /diff
# sends a direct Mini App link t.me/<bot>/<shortname>?startapp=… that opens the app
# inside Telegram in ANY chat type (web_app inline buttons are private-chat only).
# Register via BotFather /newapp with the Web App URL = BALAM_PUBLIC_URL.
# BALAM_MINIAPP_SHORTNAME=diff
# Workspace contexts file (see config.example.yaml). REQUIRED — Balam will not
# boot without it. Each context names its own working `directory`. Defaults to
# repo-root config.yaml; override the path here.
# BALAM_CONFIG_PATH=
# SQLite file backing the topic→session map (ADR-0009). Relative to the CWD.
BALAM_DB_PATH=balam.sqlite

# --- noVNC live browser view (ADR-0006) ---
# The x11vnc server exposing the agent's headed Chrome (started on demand by the
# browser-use skill, .claude/skills/browser-use/headed-browser/). The backend
# bridges /api/vnc/ws straight to this TCP endpoint; it never starts the stack.
# (Replaces the old, never-read VNC_WS_URL — delete that from a real .env.)
# BALAM_VNC_HOST=127.0.0.1
# BALAM_VNC_PORT=5900
